{{> layout/header}}

<div class="container p-5">

    <div class="card">
        <div class="card-header"><b>제품 등록</b></div>
        <div class="card-body">
            <form action="/product/save" method="post" enctype="application/x-www-form-urlencoded">
                <div class="mb-3">
                    <input type="text" class="form-control" placeholder="상품명" name="title">
                </div>
                <div class="mb-3">  
                    <select class="form-control" name="category" style="color: #595C5F;" required>
                        <option value="" disabled selected hidden>-- 카테고리 --</option>
                        <option value="electronics">전자제품</option>
                        <option value="food">식품</option>
                        <option value="beauty">미용, 화장</option>
                        <option value="clothes">의류</option>
                    </select>
                </div>
                <div class="row mb-3">
                <div class="col">
                    <input type="text" class="form-control" placeholder="가격" name="price">
                </div>
                <div class="col">
                    <input type="text" class="form-control" placeholder="수량" name="quantity">
                </div>
                </div>
                <button type="submit" class="btn btn-primary form-control">등록</button>
            </form>
        </div>
    </div>
</div>